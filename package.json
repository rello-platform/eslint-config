{
  "name": "@rello-platform/eslint-config",
  "version": "0.4.0",
  "description": "Canonical ESLint config for the Rello platform (slim Next.js baseline + slug-rule)",
  "type": "module",
  "exports": {
    "./next": {
      "import": "./next.mjs",
      "default": "./next.mjs"
    },
    "./library": {
      "import": "./library.mjs",
      "default": "./library.mjs"
    }
  },
  "files": [
    "next.mjs",
    "library.mjs"
  ],
  "publishConfig": {
