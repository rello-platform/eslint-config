  },
  "license": "UNLICENSED",
  "peerDependencies": {
    "eslint": "^9",
    "eslint-config-next": "^16.1.0"
  },
  "dependencies": {
    "@rello-platform/eslint-plugin-permissions": "github:rello-platform/eslint-plugin-permissions#v0.2.0",
    "@rello-platform/eslint-plugin-slugs": "github:rello-platform/eslint-plugin-slugs#v0.1.0",
    "@typescript-eslint/parser": "^8.59.0"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "next": "^16.1.1"
  }
