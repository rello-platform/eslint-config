{
  "name": "@rello-platform/eslint-config",
  "version": "0.6.2",
  "description": "Canonical ESLint config for the Rello platform (slim Next.js baseline + slug-rule + permissions-rule + platform-rules)",
  "type": "module",
  "exports": {
    "./next": {
      "import": "./next.mjs",
      "default": "./next.mjs"
    },
    "./library": {
      "import": "./library.mjs",
      "default": "./library.mjs"
    }
  },
  "files": [
    "next.mjs",
    "library.mjs"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rello-platform/eslint-config.git"
  },
  "license": "UNLICENSED",
  "peerDependencies": {
    "eslint": "^9",
    "eslint-config-next": "^16.1.0"
  },
  "dependencies": {
    "@rello-platform/eslint-plugin-permissions": "git+https://github.com/rello-platform/eslint-plugin-permissions.git#v0.2.0",
    "@rello-platform/eslint-plugin-platform-rules": "git+https://github.com/rello-platform/eslint-plugin-platform-rules.git#v0.1.0",
    "@rello-platform/eslint-plugin-slugs": "git+https://github.com/rello-platform/eslint-plugin-slugs.git#v0.2.1",
    "@typescript-eslint/parser": "^8.59.0"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "next": "^16.1.1"
  }
}
